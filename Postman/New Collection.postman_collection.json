    {
      "name": "Listado de razas",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Validación de status code\r",
              "pm.test(\"Status code es 200\", () => {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "// Validación de tiempo de respuesta\r",
              "pm.test(\"Tiempo de respuesta es menor a 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// Validación de estructura general\r",
              "pm.test(\"La respuesta tiene estructura de paginación\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"current_page\");\r",
              "    pm.expect(jsonData).to.have.property(\"data\");\r",
              "    pm.expect(jsonData).to.have.property(\"total\");\r",
              "    pm.expect(jsonData).to.have.property(\"per_page\");\r",
              "    pm.expect(jsonData).to.have.property(\"last_page\");\r",
              "});\r",
              "\r",
              "// Validación de array\r",
              "pm.test(\"El campo 'data' es un array\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// Validación de longitud del array\r",
              "pm.test(\"El array 'data' no está vacío\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// Validación de longitud según per_page\r",
              "pm.test(\"La cantidad de items coincide con per_page o es menor\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data.length).to.be.at.most(jsonData.per_page);\r",
              "});\r",
              "\r",
              "// Validación de campos en cada breed\r",
              "pm.test(\"Cada raza tiene los campos requeridos con tipos correctos\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    jsonData.data.forEach(breed => {\r",
              "        pm.expect(breed).to.have.property(\"breed\");\r",
              "        pm.expect(breed).to.have.property(\"country\");\r",
              "        pm.expect(breed).to.have.property(\"origin\");\r",
              "        pm.expect(breed).to.have.property(\"coat\");\r",
              "        pm.expect(breed).to.have.property(\"pattern\");\r",
              "        pm.expect(breed.breed).to.be.a(\"string\");\r",
              "        pm.expect(breed.country).to.be.a(\"string\");\r",
              "    });\r",
              "});\r",
              "\r",
              "// Estamos en la primera página\r",
              "pm.test(\"La página actual es 1\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.current_page).to.eql(1);\r",
              "});"
            ],
