    {
      "name": "Paginación de razas",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Validación de status code\r",
              "pm.test(\"Status code es 200\", () => {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "// Validación de tiempo de respuesta\r",
              "pm.test(\"Tiempo de respuesta es menor a 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// Validación clave de paginación\r",
              "pm.test(\"La página actual es 2\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.current_page).to.eql(2);\r",
              "});\r",
              "\r",
              "// Validación de campos de paginación\r",
              "pm.test(\"Los campos de paginación tienen tipos correctos\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.current_page).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.total).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.per_page).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.last_page).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Validación de URLs de navegación\r",
              "pm.test(\"Las URLs de navegación contienen el parámetro page\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.first_page_url).to.include(\"page=1\");\r",
              "    pm.expect(jsonData.next_page_url === null || jsonData.next_page_url.includes(\"page=3\")).to.be.true;\r",
              "    pm.expect(jsonData.prev_page_url).to.include(\"page=1\");\r",
              "});\r",
              "\r",
              "// Validación del array data\r",
              "pm.test(\"El array 'data' contiene razas válidas\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.data.length).to.be.above(0);\r",
              "    \r",
              "    jsonData.data.forEach(breed => {\r",
              "        pm.expect(breed).to.have.property(\"breed\");\r",
              "        pm.expect(breed.breed).to.be.a(\"string\");\r",
              "        pm.expect(breed.breed.length).to.be.above(0);\r",
              "    });\r",
              "});\r",
              "\r",
              "// Validación de rango (from y to)\r",
              "pm.test(\"Los campos 'from' y 'to' son consistentes con per_page\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.from).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.to).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.to).to.be.at.least(jsonData.from);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
