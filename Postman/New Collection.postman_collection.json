  "item": [
    {
      "name": "Fact aleatorio",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Validación de status code\r",
              "pm.test(\"Status code es 200\", () => {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "// Validación de tiempo de respuesta\r",
              "pm.test(\"Tiempo de respuesta es menor a 2000ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// Validación de Content-Type\r",
              "pm.test(\"Content-Type es application/json\", () => {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// Validación de campos obligatorios\r",
              "pm.test(\"La respuesta contiene los campos 'fact' y 'length'\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"fact\");\r",
              "    pm.expect(jsonData).to.have.property(\"length\");\r",
              "});\r",
              "\r",
              "// Validación de tipos de datos\r",
              "pm.test(\"Los campos tienen los tipos de datos correctos\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.fact).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.length).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Validación de contenido\r",
              "pm.test(\"El fact no está vacío\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.fact.trim().length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// Validación de consistencia\r",
              "pm.test(\"El campo 'length' coincide con la longitud real del fact\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.length).to.eql(jsonData.fact.length);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://catfact.ninja/fact",
          "protocol": "https",
          "host": [
            "catfact",
            "ninja"
          ],
          "path": [
            "fact"
          ]
        }
      },
      "response": []
